@model AppMovie.Models.ErrorViewModel
@{
    ViewData["Title"] = "Erreur";
}
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:40px;">
    <div>
        <div style="font-size:5rem;margin-bottom:20px;">⚠️</div>
        <h1 style="font-family:var(--font-display);font-size:3rem;letter-spacing:3px;color:var(--accent-red);margin-bottom:12px;">ERREUR</h1>
        <p style="color:var(--text-secondary);">Une erreur inattendue s'est produite.</p>
        @if (Model.ShowRequestId)
        {
            <p style="color:var(--text-muted);font-size:0.8rem;margin-top:8px;">ID: @Model.RequestId</p>
        }
        <a href="/" style="display:inline-block;margin-top:24px;color:var(--accent-red);text-decoration:none;">← Retour à l'accueil</a>
    </div>
</div>
